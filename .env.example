# ============================================================================
# musicfy backend — конфигурация окружения
#
# Скопируйте в .env и заполните. Легенда меток:
#   [REQUIRED]      — нужно всегда, без этого сервис не стартует/не работает
#   [E2E-REAL]      — нужно для полного E2E с РЕАЛЬНЫМ fal.ai (не stub)
#   [PROD]          — нужно для production-готовности (Apple/StoreKit/APNs)
#   [OPTIONAL]      — есть разумный дефолт, можно не трогать
# ============================================================================

# --- Базовое --------------------------------------------------------------
APP_ENV=dev                       # [OPTIONAL] dev | prod | test
LOG_LEVEL=INFO                    # [OPTIONAL]
HTTP_HOST=0.0.0.0                 # [OPTIONAL]
HTTP_PORT=8000                    # [OPTIONAL]

# [REQUIRED] Строка подключения к PostgreSQL (async-драйвер asyncpg).
# Локально через docker-compose с нестандартным портом: см. PG_HOST_PORT в README.
DATABASE_URL=postgresql+asyncpg://musicfy:musicfy@postgres:5432/musicfy
DB_POOL_SIZE=10                   # [OPTIONAL]
DB_MAX_OVERFLOW=20                # [OPTIONAL]
DB_ECHO=false                     # [OPTIONAL]

# [REQUIRED] Сервисный ключ для internal/webhook вызовов (НЕ пользовательский auth).
# Любая случайная строка, например: openssl rand -hex 32
API_KEY=replace-me

# [REQUIRED для админки] Отдельный ключ для админ-эндпоинтов (/v1/admin/* —
# начисление кредитов и подписки). Должен отличаться от API_KEY. openssl rand -hex 32
ADMIN_API_KEY=replace-me-admin

RATE_LIMIT_PER_MINUTE=0           # [OPTIONAL] 0 = выключен
RATE_LIMIT_BURST=60               # [OPTIONAL]

# [E2E-REAL][PROD] Публичный HTTPS-URL сервиса. Нужен, чтобы fal слал webhook'и
# на <PUBLIC_BASE_URL>/v1/webhooks/fal. Для локального E2E — туннель (ngrok/cloudflared).
# Если пусто — webhook не регистрируется, результаты подхватывает только poller.
PUBLIC_BASE_URL=

# --- Сессии пользователей -------------------------------------------------
SESSION_TTL_SECONDS=2592000       # [OPTIONAL] 30 дней

# --- Sign in with Apple (вход пользователей) ------------------------------
# [PROD] Bundle ID iOS-приложения — обязателен для верификации Apple identity token.
# Без него эндпоинт /v1/auth/apple вернёт ошибку (audience_not_configured).
APPLE_BUNDLE_ID=
# [OPTIONAL] Доп. audience через запятую (service id для web), если используется.
APPLE_ALLOWED_AUDIENCES=

# --- fal.ai (генерация) ---------------------------------------------------
# [REQUIRED для генерации] true = in-process stub (для тестов/разработки без ключа).
# Для полного E2E с реальной генерацией поставьте false и заполните FAL_API_KEY.
FAL_USE_STUB=true
# [E2E-REAL] Ключ fal.ai (https://fal.ai/dashboard/keys). Без него при FAL_USE_STUB=false
# эндпоинты генерации отдают 503.
FAL_API_KEY=
FAL_BASE_URL=https://queue.fal.run        # [OPTIONAL]
FAL_HTTP_TIMEOUT_SECONDS=30               # [OPTIONAL]
# [E2E-REAL][PROD] Секрет для проверки подписи webhook'ов fal (X-Fal-Signature, HMAC).
# Также используется stub'ом в тестах. Любая случайная строка.
FAL_WEBHOOK_SECRET=
# Модели V1 (ТЗ раздел 9). Менять обычно не нужно. [OPTIONAL]
FAL_SONG_MODEL=fal-ai/minimax-music/v2.6
FAL_REFINE_MODEL=fal-ai/ace-step/audio-to-audio
FAL_SPEECH_MODEL=fal-ai/minimax/speech-02-turbo
FAL_VOICE_CLONE_MODEL=fal-ai/minimax/voice-clone
FAL_LYRICS_LLM=anthropic/claude-3-5-haiku
FAL_DEMUCS_MODEL=fal-ai/demucs
FAL_VOICE_CHANGER_MODEL=fal-ai/elevenlabs/voice-changer
FAL_VIDEO_MODEL=fal-ai/kling-video/lipsync/audio-to-video   # легаси-алиас FAL_VIDEO_AVATAR_MODEL
# Видео-модели по режиму (ADR-007). [OPTIONAL]
FAL_VIDEO_AVATAR_MODEL=fal-ai/kling-video/lipsync/audio-to-video   # avatar + source video
FAL_VIDEO_AVATAR_IMAGE_MODEL=fal-ai/sync-lipsync/v3/image-to-video # avatar + только фото
FAL_VIDEO_VISUAL_MODEL=bytedance/seedance-2.0/text-to-video        # visual_clip без референса
FAL_VIDEO_VISUAL_IMAGE_MODEL=bytedance/seedance-2.0/image-to-video # visual_clip с референсом
FAL_VIDEO_LYRICS_BG_MODEL=                                          # lyrics_video: fal-фон за флагом (пусто = статический)

# --- App Store / StoreKit 2 (монетизация) ---------------------------------
# [PROD] App Store Server API (Issuer ID, Key ID, .p8 private key) — из App Store
# Connect → Users and Access → Integrations → In-App Purchase. Нужно для верификации
# подписанных транзакций и обработки App Store Server Notifications V2.
APPLE_STOREKIT_ISSUER_ID=
APPLE_STOREKIT_KEY_ID=
APPLE_STOREKIT_PRIVATE_KEY=               # содержимое .p8 (можно одной строкой с \n)
APPLE_STOREKIT_BUNDLE_ID=
APPLE_STOREKIT_ENVIRONMENT=Sandbox        # Sandbox | Production
# ВНИМАНИЕ: после ADR-013 окружение транзакции берётся из ВЕРИФИЦИРОВАННОГО payload
# (claim environment), а не из этой настройки; переменная кандидат в dead-config (см. Q-BILL-3).

# [PROD] true = проверять подпись JWS (x5c → Apple Root CA - G3). В production ВСЕГДА true.
# false только для локальных тестов (APP_ENV=dev|test) с синтетическими токенами.
# FAIL-FAST (ADR-013 §D3): APP_ENV=prod + false → приложение НЕ стартует (иначе любой
# аутентифицированный пользователь подделает неподписанный JWS и намайнит монеты).
APPLE_STOREKIT_VERIFY_SIGNATURE=true
# [OPTIONAL][PROD] Пин корневых сертификатов Xcode StoreKit Test (ADR-013 §D3) — конкатенация
# PEM-блоков (-----BEGIN CERTIFICATE----- ... -----END CERTIFICATE-----), экспорт из Xcode
# конкретного разработчика. Payload, чья x5c-цепочка сходится к одному из них, получает
# environment=Xcode (дедуп на пользователя+purchaseDate). ДЕФОЛТ ПУСТОЙ = Xcode-ветка на проде
# ВЫКЛЮЧЕНА (прод принимает только Apple-подписанные Production/Sandbox). Владелец РЕШИЛ включать
# на проде для тестов разработчика (Q-BILL-1); ПЕРЕД РЕАЛЬНЫМ ЗАПУСКОМ корень убрать. См. TD-010.
APPLE_STOREKIT_TEST_ROOT_CERTS=
# [OPTIONAL][PROD] CN-trust Xcode тест-сертификатов за флагом (ADR-014). ДЕФОЛТ false = прод
# строгий (поведение ADR-013 без изменений). true + VERIFY_SIGNATURE=true → доверять ЛЮБОМУ
# self-signed EC-сертификату с CN="StoreKit Testing in Xcode" (subject==issuer, срок валиден,
# подпись верна) → environment=Xcode БЕЗ пина по DER. Нужно, т.к. у каждой машины Xcode свой
# уникальный DER — пин поштучно не масштабируется на нескольких тестеров.
# !!! РИСК: при true на проде ЛЮБОЙ намайнит коины БЕСПЛАТНО СЕБЕ на аккаунт (per-user; чужой
# баланс и боевой namespace недостижимы). ПРИЕМЛЕМО ТОЛЬКО в Testing-режиме до публичного релиза.
# Флаг легален в prod (fail-fast НЕТ) — единственная защита дефолт false + pre-launch чеклист.
# ПЕРЕД ПУБЛИЧНЫМ РЕЛИЗОМ выключить (false) И убрать APPLE_STOREKIT_TEST_ROOT_CERTS (DEPLOYMENT §8).
APPLE_STOREKIT_TRUST_XCODE_TEST_CERTS=false

# --- APNs (push на завершение долгих задач, прежде всего видео) ------------
# [PROD] false = уведомления только логируются. Для реальных push заполните ключ APNs
# (.p8 token-based), Key ID, Team ID и topic (= bundle id).
APNS_ENABLED=false
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_PRIVATE_KEY=                         # содержимое .p8 APNs-ключа
APNS_TOPIC=
APNS_USE_SANDBOX=true

# --- Лимиты / загрузки ----------------------------------------------------
MAX_CONCURRENT_GENERATIONS=8              # [OPTIONAL]
UPLOAD_MAX_BYTES=52428800                 # [OPTIONAL] 50 MiB
UPLOAD_AUDIO_CONTENT_TYPES=audio/mpeg,audio/wav,audio/mp4,audio/x-m4a,audio/aac
UPLOAD_VIDEO_CONTENT_TYPES=video/mp4,video/quicktime
UPLOAD_IMAGE_CONTENT_TYPES=image/jpeg,image/png,image/webp
DEFAULT_TRACK_DURATION_SECONDS=60         # [OPTIONAL]
JOB_HARD_TIMEOUT_SECONDS=1800             # [OPTIONAL]
VIDEO_JOB_HARD_TIMEOUT_SECONDS=5400       # [OPTIONAL] видео — самая долгая операция

URL_CHECK_ENABLED=true                    # [OPTIONAL]
URL_CHECK_TIMEOUT_SECONDS=3.0             # [OPTIONAL]

# --- Опрос статусов fal (fallback к webhook) ------------------------------
POLL_ENABLED=true                         # [OPTIONAL]
POLL_INTERVAL_SECONDS=10                  # [OPTIONAL]
VIDEO_POLL_INTERVAL_SECONDS=30            # [OPTIONAL]
