# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
*.egg
build/
dist/
sdist/
wheels/
*.manifest
*.spec

# ============================================================================
# Виртуальные окружения
# ============================================================================
.venv/
venv/
env/
ENV/

# ============================================================================
# Переменные окружения / секреты
# ============================================================================
.env
.env.*
!.env.example
*.pem
*.key

# ============================================================================
# Тесты, линтеры, типизация, coverage
# ============================================================================
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.cache/
.tox/
.hypothesis/

# ============================================================================
# Базы данных (локальные)
# Внимание: миграции Alembic (migrations/versions/) коммитятся — НЕ игнорировать.
# ============================================================================
*.sqlite
*.sqlite3
*.db

# ============================================================================
# Логи и runtime
# ============================================================================
*.log
*.pid
*.pid.lock

# ============================================================================
# IDE / редакторы
# ============================================================================
.idea/
.vscode/
*.swp
*.swo
*~

# ============================================================================
# OS
# ============================================================================
.DS_Store
Thumbs.db
Desktop.ini

# ============================================================================
# Внутреннее (оркестрация агентов / приватные материалы — не для публикации)
# ============================================================================
.claude/
CLAUDE.md
tz.txt

# Сертификаты (StoreKit test root и пр.) — конфиг, не код; в репозиторий не входят
*.cer
*.pem
*.der
